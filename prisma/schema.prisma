generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Ticker registry ───────────────────────────────────────────────────────────
model Ticker {
  id        Int      @id @default(autoincrement())
  symbol    String   @unique
  name      String
  exchange  String?
  sector    String?
  industry  String?
  fullyIngested Boolean @default(false)  // true once all FMP history fetched
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taSnapshots          TASnapshot[]
  aiReports            AIReport[]
  valuationReports     ValuationReport[]

  @@index([symbol])
}

// ── Raw market data (keyed by symbol+date, no FK — supports S&P 500 bulk load) ─

model OHLCVBar {
  id     Int    @id @default(autoincrement())
  symbol String
  date   String // YYYY-MM-DD
  open   Float
  high   Float
  low    Float
  close  Float
  volume BigInt

  @@unique([symbol, date])
  @@index([symbol, date])
}

model MarketCapHistory {
  id        Int    @id @default(autoincrement())
  symbol    String
  date      String // YYYY-MM-DD
  marketCap BigInt

  @@unique([symbol, date])
  @@index([symbol])
  @@index([date])
}

// ── Financial statements ──────────────────────────────────────────────────────

model IncomeStatement {
  id                              Int    @id @default(autoincrement())
  symbol                          String
  date                            String // fiscal year-end date
  period                          String // 'annual' | 'quarterly'
  fiscalYear                      String?
  reportedCurrency                String?
  revenue                         BigInt?
  costOfRevenue                   BigInt?
  grossProfit                     BigInt?
  operatingExpenses               BigInt?
  operatingIncome                 BigInt?
  interestExpense                 BigInt?
  interestIncome                  BigInt?
  ebitda                          BigInt?
  ebit                            BigInt?
  incomeBeforeTax                 BigInt?
  incomeTaxExpense                BigInt?
  netIncome                       BigInt?
  eps                             Float?
  epsDiluted                      Float?
  weightedAverageShsOut           BigInt?
  weightedAverageShsOutDil        BigInt?

  @@unique([symbol, date, period])
  @@index([symbol, period, date])
}

model BalanceSheet {
  id                          Int    @id @default(autoincrement())
  symbol                      String
  date                        String
  period                      String
  fiscalYear                  String?
  reportedCurrency            String?
  cashAndCashEquivalents      BigInt?
  shortTermInvestments        BigInt?
  netReceivables              BigInt?
  inventory                   BigInt?
  totalCurrentAssets          BigInt?
  totalAssets                 BigInt?
  totalCurrentLiabilities     BigInt?
  longTermDebt                BigInt?
  totalDebt                   BigInt?
  totalLiabilities            BigInt?
  totalStockholdersEquity     BigInt?
  minorityInterest            BigInt?
  totalEquity                 BigInt?
  shortTermInvestmentsProp    BigInt?  // shortTermInvestments for NOA calc
  longTermInvestments         BigInt?

  @@unique([symbol, date, period])
  @@index([symbol, period, date])
}

model CashFlowStatement {
  id                              Int    @id @default(autoincrement())
  symbol                          String
  date                            String
  period                          String
  fiscalYear                      String?
  reportedCurrency                String?
  netIncome                       BigInt?
  depreciationAndAmortization     BigInt?
  operatingCashFlow               BigInt?
  capitalExpenditure              BigInt?
  freeCashFlow                    BigInt?
  dividendsPaid                   BigInt?
  commonStockRepurchased          BigInt?
  netCashProvidedByFinancing      BigInt?
  netChangeInCash                 BigInt?

  @@unique([symbol, date, period])
  @@index([symbol, period, date])
}

// ── Company profile ───────────────────────────────────────────────────────────

model CompanyProfile {
  symbol          String  @id
  name            String
  exchange        String?
  sector          String?
  industry        String?
  beta            Float?
  marketCap       BigInt?
  price           Float?
  website         String?
  description     String?
  ceo             String?
  country         String?
  fullTimeEmployees String?
  ipoDate         String?
  isEtf           Boolean @default(false)
  fetchedAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── S&P 500 constituents ──────────────────────────────────────────────────────

model Sp500Constituent {
  symbol          String  @id
  name            String
  sector          String?
  subSector       String?
  headQuarter     String?
  dateFirstAdded  String?
  founded         String?
  updatedAt       DateTime @updatedAt
}

// ── App state (TA, AI reports, valuations) ────────────────────────────────────

model TASnapshot {
  id         Int      @id @default(autoincrement())
  tickerId   Int
  ticker     Ticker   @relation(fields: [tickerId], references: [id])
  capturedAt DateTime @default(now())
  period     String

  currentPrice   Float
  priceChange    Float
  priceChangePct Float

  sma20   Float?
  sma50   Float?
  sma200  Float?
  ema12   Float?
  ema26   Float?

  rsi14   Float?
  stochK  Float?
  stochD  Float?
  adx14   Float?
  diPlus  Float?
  diMinus Float?

  macdLine   Float?
  macdSignal Float?
  macdHist   Float?

  bbUpper  Float?
  bbMiddle Float?
  bbLower  Float?
  bbWidth  Float?
  atr14    Float?

  obv         Float?
  volumeSMA20 Float?
  volumeRatio Float?

  supportLevels    String?
  resistanceLevels String?
  overallSignal    String?
  signalScore      Int?

  @@index([tickerId, period, capturedAt])
}

model AIReport {
  id          Int      @id @default(autoincrement())
  tickerId    Int
  ticker      Ticker   @relation(fields: [tickerId], references: [id])
  generatedAt DateTime @default(now())
  period      String
  taInputJson String
  reportText  String
  tokensUsed  Int?
  modelUsed   String   @default("claude-sonnet-4-6")
  likes       Int      @default(0)
  comments    ReportComment[]

  @@index([tickerId, generatedAt])
}

model ReportComment {
  id        Int      @id @default(autoincrement())
  reportId  Int
  report    AIReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([reportId, createdAt])
}

model ValuationReport {
  id          Int      @id @default(autoincrement())
  tickerId    Int
  ticker      Ticker   @relation(fields: [tickerId], references: [id])
  generatedAt DateTime @default(now())

  inputsJson  String
  resultsJson String
  reportText  String?

  intrinsicValue Float
  currentPrice   Float
  marginOfSafety Float

  modelUsed String @default("claude-sonnet-4-6")
  likes     Int    @default(0)

  @@index([tickerId, generatedAt])
}

model SearchLog {
  id         Int      @id @default(autoincrement())
  symbol     String
  searchType String
  searchedAt DateTime @default(now())
  price      Float?
  result     String   @default("success")
  errorMsg   String?

  @@index([symbol, searchedAt])
  @@index([searchedAt])
}

// ── Scanner ───────────────────────────────────────────────────────────────────

model WatchlistTicker {
  id      Int      @id @default(autoincrement())
  symbol  String   @unique
  name    String   @default("")
  sector  String?
  addedAt DateTime @default(now())
  active  Boolean  @default(true)

  scanResults ScanResult[]

  @@index([symbol])
}

model ScanResult {
  id     Int      @id @default(autoincrement())
  symbol String
  name   String   @default("")

  scannedAt      DateTime @default(now())
  price          Float
  priceChangePct Float

  overallSignal String
  signalScore   Int

  sniperGrade String
  sniperScore Int

  rsi14       Float?
  macdHist    Float?
  bbWidth     Float?
  adx14       Float?
  volumeRatio Float?
  atr14       Float?

  sma20   Float?
  sma50   Float?
  sma200  Float?

  aboveSma20  Boolean @default(false)
  aboveSma50  Boolean @default(false)
  aboveSma200 Boolean @default(false)
  macdBullish Boolean @default(false)

  watchlistTicker WatchlistTicker @relation(fields: [symbol], references: [symbol])

  @@index([symbol, scannedAt])
  @@index([scannedAt])
  @@index([overallSignal])
  @@index([sniperGrade])
}
